# Local mode is the default and uses the CSV files committed in data/.
DATA_BACKEND=local

# Path C mode: set these values on Render, not in the repository.
# DATA_BACKEND=tinybird
# TINYBIRD_API_BASE=https://api.tinybird.co
# TINYBIRD_TOKEN=replace_with_tinybird_read_token
# REQUIRE_TINYBIRD=false

# Optional pipe name overrides. Leave these alone if you use the names in tinybird/pipes/.
# TINYBIRD_PIPE_QUARTERLY=nike_quarterly_metrics_api
# TINYBIRD_PIPE_DIVISIONAL=nike_divisional_revenue_api
# TINYBIRD_PIPE_SENTIMENT=nike_news_sentiment_api
# TINYBIRD_PIPE_STOCK=nke_stock_prices_api
# TINYBIRD_PIPE_SOCIAL=nike_social_snapshot_api
# TINYBIRD_PIPE_INSTAGRAM=nike_instagram_followers_api
